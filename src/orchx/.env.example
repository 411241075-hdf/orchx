# orchX env — пример конфига для OpenAI-совместимого Proxy.
# Скопируй в `orchx/.env` и заполни своими значениями:
#     cp orchx/.env.example orchx/.env
#
# Загрузить в shell:
#     set -a; source orchx/.env; set +a
#     orchx all "<task>"
# Или через direnv (.envrc):
#     dotenv orchx/.env

# Обязательные — без них рой не стартует.
ORCHX_LLM_BASE_URL=https://your-proxy.example.com/v1
ORCHX_LLM_API_KEY=sk-...
ORCHX_MODEL=anthropic/claude-sonnet-4-6

# Опциональные.
# ORCHX_TIMEOUT_S=600                # HTTP-таймаут на один запрос к Proxy.
# ORCHX_PLANNER_MODEL=...            # per-role override модели для planner.
# ORCHX_REVIEWER_MODEL=...           # per-role override для reviewer.
# ORCHX_DEBUGGER_MODEL=...
# ORCHX_MERGER_MODEL=...
