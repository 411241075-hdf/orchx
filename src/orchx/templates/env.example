# orchX env — пример конфига для OpenAI-совместимого Proxy.
# Скопируй в `.orchx/.env` и заполни своими значениями:
#     cp .orchx/.env.example .orchx/.env
#
# orchX автоматически подхватит этот файл при запуске. Переменные,
# выставленные в shell, имеют приоритет над файлом.

# ───────────────────────────────────────────────────────────────────────
# Обязательные — без них рой не стартует.
# ───────────────────────────────────────────────────────────────────────

# Base URL твоего OpenAI-совместимого Proxy / OpenRouter / vLLM.
# Любой эндпоинт, поддерживающий /v1/chat/completions с tool calling.
ORCHX_LLM_BASE_URL=https://your-proxy.example.com/v1

# API-ключ для Proxy.
ORCHX_LLM_API_KEY=sk-...

# Дефолтная модель для всех ролей. Должна поддерживать tool calling и
# (для reviewer/debugger/planner) reasoning-effort. Рекомендованные:
#   anthropic/claude-sonnet-4-6
#   anthropic/claude-opus-4-7
#   openai/gpt-5
ORCHX_MODEL=anthropic/claude-sonnet-4-6

# ───────────────────────────────────────────────────────────────────────
# Опциональные — per-role override модели.
# ───────────────────────────────────────────────────────────────────────

# ORCHX_PLANNER_MODEL=anthropic/claude-opus-4-7
# ORCHX_REVIEWER_MODEL=anthropic/claude-opus-4-7
# ORCHX_DEBUGGER_MODEL=anthropic/claude-opus-4-7
# ORCHX_MERGER_MODEL=anthropic/claude-sonnet-4-6

# HTTP-таймаут на один запрос к Proxy (default 600 секунд).
# ORCHX_TIMEOUT_S=600

# Отключить компактный TUI (live-доска прогресса) — для CI / non-TTY.
# Также автоматически отключается, если stdout не TTY.
# ORCHX_NO_TUI=1
